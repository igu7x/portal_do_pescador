# Chave da API da Anthropic (Claude). Obrigatória.
# Compre crédito em: https://console.anthropic.com/settings/billing
# Gere a chave em:    https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-cole-sua-chave-aqui

# Modelo Claude para a conversa (opcional). Padrão: claude-sonnet-4-6
# Outras opções: claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# Conexão com o PostgreSQL. Obrigatória.
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
# Exemplo (Postgres local com usuário/senha padrão e banco "pescador"):
DATABASE_URL=postgresql://postgres:senha-aqui@localhost:5432/pescador
